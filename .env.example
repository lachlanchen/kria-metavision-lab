## Suggested manual action flow (for your password-protected session)
SUPPORT_AUTH_WORKFLOW="Open KB page in browser, login, then copy KB article JSON from API or browser network panel."
SUPPORT_AUTH_MANUAL_BROWSER_HINT="This environment cannot execute a GUI login flow; use a real browser and copy support.prophesee.ai authenticated session cookies."
SUPPORT_AUTOMATION_MODE=run-with-session-cookie-only
SUPPORT_API_RATE_LIMIT_NOTES="rate limits and anti-bot protection may block automated login from scripts."
SUPPORT_COOKIE_AUTOMATION_NOTE="If you can run a browser on another host, use its devtools/network tab to copy request headers/cookie for the article API."
SUPPORT_KV260_GATE_ARTIFACTS=linux_sd_image,upgrade_rpm_packets,sdk_toolchain,active_marker_zip

PROPHESSEE_SUPPORT_HELPER_ARTICLE_DUMP_SCRIPT=$PROJECT_ROOT/scripts/prophesee-support-dump.sh

## Local workflow state
MANUAL_STATUS=linux_system_validated
GUI_PREFERENCE=headless_default_lightmatchbox
RDP_STATUS=xrdp_enabled_in_config_feed_packages_not_available

## KV260 headless recording API for Windows/Arduino experiments
KV260_EVENT_API_URL=http://<kv260-ip>:8765
KV260_EVENT_API_HOST=0.0.0.0
KV260_EVENT_API_PORT=8765
KV260_EVENT_API_RECORD_DIR=/home/petalinux/event_recordings
KV260_EVENT_API_DEVICE=/dev/video0
KV260_EVENT_API_TOKEN=
## Set KV260_EVENT_API_TOKEN for LAN auth if the API is reachable from untrusted machines.

## Windows Arduino CLI / light-control API plan
KV260_ARDUINO_API_URL=http://127.0.0.1:8780
KV260_ARDUINO_CLI_PATH=arduino-cli
KV260_ARDUINO_PORT=COM3
KV260_ARDUINO_BAUD=115200
KV260_ARDUINO_FQBN=arduino:avr:uno
KV260_ARDUINO_CORE=arduino:avr
KV260_ARDUINO_SKETCH_DIR=C:/Users/Administrator/Projects/petalinux/kv260-remote-gui/arduino/LightController
KV260_ARDUINO_LIGHT_ON_COMMAND=ON
KV260_ARDUINO_LIGHT_OFF_COMMAND=OFF
