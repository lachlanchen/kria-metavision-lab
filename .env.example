PROPHESSEE_SUPPORT_AUTH_WORKFLOW="Use real browser login, export authenticated cookies for support.prophesee.ai domain, then retry with --cookie-file"
PROPHESSEE_SUPPORT_USERNAME=
PROPHESSEE_SUPPORT_PASSWORD=
## Do not hardcode real credentials in this repo; read them from your password manager/secret store at runtime.

